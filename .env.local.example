# ══════════════════════════════════════════════════════════════
# PLANFORGE — Variabili d'ambiente
# Rinomina questo file in .env.local per lo sviluppo locale
# Su Vercel incollale in Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ─── SUPABASE ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ⚠️  SUPABASE SERVICE ROLE KEY — recupera da Supabase Dashboard:
#     Settings → API → "service_role" (mai esporre al client!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── GOOGLE GEMINI (gratuito) ──────────────────────────────────
# Ottieni su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── STRIPE (monetizzazione) ───────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── URL app ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
